DISCORD_BOT_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# AI Provider: "openai" (default) or "nvidia"
# AI_PROVIDER=nvidia
# NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_BASE_URL=https://inference-api.nvidia.com
# NVIDIA_MODEL=aws/anthropic/bedrock-claude-opus-4-6
# NVIDIA_FAST_MODEL=aws/anthropic/claude-haiku-4-5-v1
DATABASE_URL=sqlite:///data/degen_live.db

# Durable runtime data root. Defaults to repo-relative `data/` for local dev;
# Green/Linux production should set DATA_ROOT=/opt/degen/data so attachments,
# hit images, v2 captures, and the pHash index live outside the app checkout.
# Optional MEDIA_ROOT splits user-uploaded media (attachments + hit images)
# from operational data; leave unset to inherit DATA_ROOT.
# DATA_ROOT=/opt/degen/data
# MEDIA_ROOT=
DISCORD_CHANNEL_IDS=
PUBLIC_BASE_URL=http://127.0.0.1:8000
SESSION_COOKIE_NAME=degen_session
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=strict
SESSION_DOMAIN=
STITCH_WINDOW_SECONDS=30
STITCH_MAX_MESSAGES=3
SESSION_SECRET=change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_DISPLAY_NAME=Degen Admin
REVIEWER_USERNAME=
REVIEWER_PASSWORD=
REVIEWER_DISPLAY_NAME=Degen Reviewer

# Employee portal
EMPLOYEE_PORTAL_ENABLED=false
EMPLOYEE_PII_KEY=
EMPLOYEE_EMAIL_HASH_SALT=
EMPLOYEE_TOKEN_HMAC_KEY=
SMS_PROVIDER=dry_run
SMS_FROM_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
SMS_TIMEOUT_SECONDS=10
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=
CLOCKIFY_BASE_URL=https://api.clockify.me/api/v1
CLOCKIFY_TIMEZONE=America/Los_Angeles
CLOCKIFY_TIMEOUT_SECONDS=12

SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here
SHOPIFY_API_KEY=your_shopify_admin_access_token_here
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Shopify private app token for outbound product creation (needs write_products + write_inventory scopes):
SHOPIFY_ACCESS_TOKEN=your_shopify_private_app_token_here

# Inventory / auto-pricing
SCRYDEX_API_KEY=your_scrydex_api_key_here
SCRYDEX_BASE_URL=https://api.scrydex.io
INVENTORY_AUTO_PRICE_ENABLED=true
INVENTORY_AUTO_SHOPIFY_PUSH=false
# INVENTORY_PRICE_REFRESH_INTERVAL_HOURS=6
# INVENTORY_PRICE_STALE_HOURS=24

# Card scanning
# Ximilar Collectibles API token (visual card recognition — https://app.ximilar.com/)
XIMILAR_API_TOKEN=your_ximilar_api_token_here
# PSA free key: https://www.psacard.com/api (register for free tier)
PSA_API_KEY=your_psa_api_key_here
# Legacy OCR pipeline fallback (used only when XIMILAR_API_TOKEN is not set):
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
# Degen Eye v2 saves full employee scan photos plus confirmed labels for eval/training.
DEGEN_EYE_V2_CAPTURE_ENABLED=true
DEGEN_EYE_V2_CAPTURE_DIR=data/v2_training_scans
DEGEN_EYE_V2_INDEX_PATH=data/phash_index.sqlite

# Firecrawl (web scraping API — https://firecrawl.dev)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Optional external TikTok username resolver (scripts/scraper_server.py
# running on OpenClaw). When both are set the app can call it to resolve
# buyer @usernames from order_ids. See scripts/README_scraper.md.
# USERNAME_SCRAPER_BASE_URL=http://openclaw.tailnet-name.ts.net:8787
# USERNAME_SCRAPER_API_KEY=your_scraper_api_key_here
# USERNAME_SCRAPER_TIMEOUT_SECONDS=8

TIKTOK_APP_KEY=your_tiktok_app_key_here
TIKTOK_APP_SECRET=your_tiktok_app_secret_here
TIKTOK_REDIRECT_URI=https://ops.degencollectibles.com/integrations/tiktok/callback
TIKTOK_SHOP_ID=your_tiktok_shop_id_here
TIKTOK_SHOP_CIPHER=your_tiktok_shop_cipher_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token_here
# TikTok Shop API base URL (defaults to https://open-api.tiktokglobalshop.com):
# TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com
# Generic TikTok API host (used for OAuth token exchange):
# TIKTOK_BASE_URL=https://open.tiktokapis.com
# Periodic TikTok order sync:
# TIKTOK_SYNC_ENABLED=true
# TIKTOK_SYNC_INTERVAL_MINUTES=15
# TIKTOK_SYNC_LOOKBACK_HOURS=24
# TIKTOK_SYNC_LIMIT=100

# For a shared local + hosted setup, switch DATABASE_URL to Postgres, for example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# For a dedicated worker host or VPS:
# DISCORD_INGEST_ENABLED=true
# PARSER_WORKER_ENABLED=true
# STARTUP_BACKFILL_ENABLED=false
# Run with:
# python -m app.worker_service

# To recover recent edits and deletions after downtime without scanning full history:
# STARTUP_OFFLINE_AUDIT_ENABLED=true
# STARTUP_OFFLINE_AUDIT_LOOKBACK_HOURS=24
# STARTUP_OFFLINE_AUDIT_LIMIT_PER_CHANNEL=250
# STARTUP_OFFLINE_AUDIT_OLDEST_FIRST=true

# For fast local UI / design work with hot reload and no shared Postgres lag:
# PowerShell:
# .\scripts\run_ui_dev.ps1
# This uses a local SQLite copy at data/degen_ui_dev.db with:
# DISCORD_INGEST_ENABLED=false
# PARSER_WORKER_ENABLED=false
# STARTUP_BACKFILL_ENABLED=false

# For offline edit/delete recovery on the host:
# STARTUP_OFFLINE_AUDIT_ENABLED=true
# STARTUP_OFFLINE_AUDIT_LOOKBACK_HOURS=24
# PERIODIC_OFFLINE_AUDIT_ENABLED=true
# PERIODIC_OFFLINE_AUDIT_INTERVAL_MINUTES=30

# For a bounded recent stitch audit on the host:
# PERIODIC_STITCH_AUDIT_ENABLED=true
# PERIODIC_STITCH_AUDIT_INTERVAL_MINUTES=45
# PERIODIC_STITCH_AUDIT_LOOKBACK_HOURS=24
# PERIODIC_STITCH_AUDIT_LIMIT=50
# PERIODIC_STITCH_AUDIT_MIN_AGE_MINUTES=10

# PERIODIC_ATTACHMENT_REPAIR_ENABLED=true
# PERIODIC_ATTACHMENT_REPAIR_INTERVAL_MINUTES=60
# PERIODIC_ATTACHMENT_REPAIR_LOOKBACK_HOURS=24
# PERIODIC_ATTACHMENT_REPAIR_LIMIT=50
# PERIODIC_ATTACHMENT_REPAIR_MIN_AGE_MINUTES=10

# For a split local host setup on one machine:
# Single launcher:
# powershell -ExecutionPolicy Bypass -File .\scripts\run_local_host.ps1
# Or launch the two windows manually:
# powershell -ExecutionPolicy Bypass -File .\scripts\run_local_web.ps1
# powershell -ExecutionPolicy Bypass -File .\scripts\run_local_worker.ps1
# Both processes share the same host runtime name (`local_host`) so the status
# page can line up the web and worker heartbeats correctly.
